<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0e0c07">

    <!-- Content Area (Holds the Tabs) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavBar">

        <!-- TAB 1: Home / Status View -->
        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/ic_launcher_background"
                android:backgroundTint="#ffcc00"
                android:gravity="center"
                android:text="🛡️"
                android:textSize="50sp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MTN Smart Filter"
                android:textColor="#ffcc00"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● ACTIVE &amp; MONITORING"
                android:textColor="#2fb673"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- TAB 2: Threat Log View (Hidden by default) -->
        <LinearLayout
            android:id="@+id/tabLogs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INTERCEPTION LOG"
                android:textColor="#ffcc00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/threatLogContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/emptyLogText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No spam detected yet. Inbox is safe."
                        android:textColor="#9a927a"
                        android:textSize="14sp"
                        android:textAlignment="center"
                        android:layout_marginTop="40dp"/>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

    </FrameLayout>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="#17140c"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🛡️ Status"
            android:textColor="#ffcc00"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navLogs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📋 Logs"
            android:textColor="#9a927a"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>